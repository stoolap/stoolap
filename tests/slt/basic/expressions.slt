# Expression tests: arithmetic, CASE, operators

# Arithmetic operators
query IIIII
SELECT 2 + 3, 10 - 4, 3 * 7, 15 / 4, 17 % 5
----
5 6 21 3 2

# Float arithmetic
query RRR
SELECT 1.0 + 2.5, 10.0 / 3.0, 2.5 * 4.0
----
3.500 3.333 10.000

# Division by zero returns NULL in stoolap
query I
SELECT 1 / 0
----
NULL

# String concatenation with ||
query T
SELECT 'Hello' || ' ' || 'World'
----
Hello World

# CASE WHEN simple form
query T
SELECT CASE 1 WHEN 1 THEN 'one' WHEN 2 THEN 'two' ELSE 'other' END
----
one

# CASE WHEN searched form
query T
SELECT CASE WHEN 5 > 3 THEN 'yes' ELSE 'no' END
----
yes

# CASE WHEN with NULL
query T
SELECT CASE WHEN NULL THEN 'yes' ELSE 'no' END
----
no

# CASE with no ELSE (implicit NULL)
query T
SELECT CASE WHEN 1 = 2 THEN 'match' END
----
NULL

# CASE with multiple WHEN branches
query T
SELECT CASE WHEN 1 > 10 THEN 'a' WHEN 1 > 5 THEN 'b' WHEN 1 > 0 THEN 'c' ELSE 'd' END
----
c

# Nested CASE expressions
query T
SELECT CASE WHEN true THEN CASE WHEN false THEN 'inner_true' ELSE 'inner_false' END ELSE 'outer' END
----
inner_false

# BETWEEN (inclusive)
statement ok
CREATE TABLE expr_test (id INTEGER PRIMARY KEY, val INTEGER)

statement ok
INSERT INTO expr_test VALUES (1, 5), (2, 10), (3, 15), (4, 20), (5, 25)

query II rowsort
SELECT id, val FROM expr_test WHERE val BETWEEN 10 AND 20
----
2 10
3 15
4 20

# NOT BETWEEN
query II rowsort
SELECT id, val FROM expr_test WHERE val NOT BETWEEN 10 AND 20
----
1 5
5 25

# IN with literal list
query II rowsort
SELECT id, val FROM expr_test WHERE val IN (5, 15, 25)
----
1 5
3 15
5 25

# NOT IN
query II rowsort
SELECT id, val FROM expr_test WHERE val NOT IN (5, 15, 25)
----
2 10
4 20

# Operator precedence: AND vs OR
# AND has higher precedence: 1=1 OR (1=2 AND 1=3) => true OR false => true
query T
SELECT CASE WHEN 1=1 OR 1=2 AND 1=3 THEN 'true' ELSE 'false' END
----
true

# Parenthesized expressions override precedence
# (1=1 OR 1=2) AND 1=3 => true AND false => false
query T
SELECT CASE WHEN (1=1 OR 1=2) AND 1=3 THEN 'true' ELSE 'false' END
----
false

# Arithmetic precedence: * before +
query I
SELECT 2 + 3 * 4
----
14

query I
SELECT (2 + 3) * 4
----
20

# Bitwise operators
query IIII
SELECT 12 & 10, 12 | 10, 12 ^ 10, ~0
----
8 14 6 -1

query II
SELECT 1 << 4, 256 >> 3
----
16 32

# Boolean logic with NULL (three-valued)
# true AND NULL = NULL
query T
SELECT CASE WHEN true AND NULL THEN 'true' WHEN NOT (true AND NULL) THEN 'false' ELSE 'null' END
----
null

# false AND NULL = false (short-circuit)
query T
SELECT CASE WHEN false AND NULL THEN 'true' WHEN NOT (false AND NULL) THEN 'false' ELSE 'null' END
----
false

# true OR NULL = true (short-circuit)
query T
SELECT CASE WHEN true OR NULL THEN 'true' WHEN NOT (true OR NULL) THEN 'false' ELSE 'null' END
----
true

# false OR NULL = NULL
query T
SELECT CASE WHEN false OR NULL THEN 'true' WHEN NOT (false OR NULL) THEN 'false' ELSE 'null' END
----
null

# CASE WHEN with table data
query IT
SELECT id, CASE WHEN val > 15 THEN 'high' WHEN val > 5 THEN 'mid' ELSE 'low' END AS category FROM expr_test ORDER BY id
----
1 low
2 mid
3 mid
4 high
5 high

statement ok
DROP TABLE expr_test
