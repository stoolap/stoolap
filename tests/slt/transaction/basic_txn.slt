# Transaction tests

statement ok
CREATE TABLE txn_test (id INTEGER PRIMARY KEY, value INTEGER)

statement ok
INSERT INTO txn_test VALUES (1, 100), (2, 200)

# BEGIN + COMMIT
statement ok
BEGIN

statement ok
INSERT INTO txn_test VALUES (3, 300)

statement ok
COMMIT

query I
SELECT COUNT(*) FROM txn_test
----
3

# BEGIN + ROLLBACK (data not visible after rollback)
statement ok
BEGIN

statement ok
INSERT INTO txn_test VALUES (4, 400)

statement ok
ROLLBACK

query I
SELECT COUNT(*) FROM txn_test
----
3

# Autocommit (implicit transactions)
statement ok
INSERT INTO txn_test VALUES (5, 500)

query I
SELECT value FROM txn_test WHERE id = 5
----
500

# Transaction with multiple statements
statement ok
BEGIN

statement ok
UPDATE txn_test SET value = 999 WHERE id = 1

statement ok
DELETE FROM txn_test WHERE id = 2

statement ok
INSERT INTO txn_test VALUES (6, 600)

statement ok
COMMIT

query II rowsort
SELECT id, value FROM txn_test
----
1 999
3 300
5 500
6 600

# Rollback undoes all changes
statement ok
BEGIN

statement ok
DELETE FROM txn_test

statement ok
ROLLBACK

query I
SELECT COUNT(*) FROM txn_test
----
4

statement ok
DROP TABLE txn_test
